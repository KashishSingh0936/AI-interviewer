# AI Interview Platform - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============= DATABASE =============
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://interview_user:your_secure_password@localhost:5432/ai_interview_db
SQLALCHEMY_ECHO=False

# ============= JWT SECURITY =============
# Generate a secure secret key (32+ random characters):
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=KASHISHSINGHRAJPUT3714
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ============= AI/ML =============
# Get from https://console.groq.com
GROQ_API_KEY=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
# ============= SERVER CONFIGURATION =============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development  # development | production

# ============= FILE STORAGE =============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes

# ============= EMAIL (OPTIONAL) =============
# For sending interview notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-password

# ============= CORS =============
# Frontend URL for CORS validation
FRONTEND_URL=http://localhost:3000

# ============= LOGGING =============
LOG_LEVEL=INFO
LOG_FORMAT=json
